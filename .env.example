# 八卦 - I Ching Divination Configuration
# 复制此文件为 .env 并填入你的值
# 切勿将 .env 提交到版本控制
#
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# ── AI 解卦配置（三选一） ──────────────────────────────

# 方案 A：智谱 GLM-4-Flash（永久免费，推荐）
# 注册 https://open.bigmodel.cn/ 获取 API Key
# ANTHROPIC_API_KEY=你的智谱key
# ANTHROPIC_BASE_URL=https://open.bigmodel.cn/api/anthropic
# ANTHROPIC_MODEL=glm-4-flash

# 方案 B：DeepSeek（付费，效果更好）
ANTHROPIC_API_KEY=sk-your-key-here
ANTHROPIC_BASE_URL=https://api.deepseek.com/anthropic
ANTHROPIC_MODEL=deepseek-v4-pro

# 方案 C：Anthropic 官方（付费）
# ANTHROPIC_BASE_URL=https://api.anthropic.com

# ── 服务器配置 ──────────────────────────────────────────

# Redis 缓存（可选，不可用时自动降级）
REDIS_URL=redis://localhost:6379/0
REDIS_TTL=3600

# 应用设置
DEBUG=true
DATABASE_URL=sqlite+aiosqlite:///./data/iching.db
HOST=127.0.0.1
PORT=8088
